// SpryCode Example — Microservice Patterns (Phase 110)
// Demonstrates: loop, retry, Queue, Channel, CircuitBreaker, throttle, debounce

app MicroserviceDemo version "1.0.0"

// ── loop: infinite loop until break ──────────────────────────────────────
task pollUntilReady {
    var attempts = 0

    loop {
        attempts += 1
        log info "Polling... attempt " + str(attempts)

        if attempts >= 3 {
            log info "Service is ready"
            break
        }
    }
}

// ── retry block ───────────────────────────────────────────────────────────
task fetchWithRetry {
    var tries = 0

    try {
        retry(3) {
            tries += 1
            log info "Attempt " + str(tries)
            if tries < 3 {
                throw "Transient error"
            }
            log info "Fetch succeeded on attempt " + str(tries)
        }
    } catch err {
        log error "All retries exhausted: " + str(err)
    }
}

// ── Queue: FIFO message buffer ────────────────────────────────────────────
task queueDemo {
    let inbox = new Queue()

    // Producer: enqueue work items
    inbox.enqueue("order:001")
    inbox.enqueue("order:002")
    inbox.enqueue("order:003")

    log info "Inbox size: " + str(inbox.size)

    // Consumer: drain the queue
    loop {
        if inbox.isEmpty() { break }
        let item = inbox.dequeue()
        log info "Processing " + item
    }

    log info "Queue empty: " + str(inbox.isEmpty())
}

// ── Channel: typed message passing ───────────────────────────────────────
task channelDemo {
    let eventCh = new Channel()

    // Producer service emits events
    let events = ["user.login", "payment.ok", "order.shipped"]
    for ev in events {
        eventCh.send(ev)
    }

    log info "Channel size: " + str(eventCh.size)

    // Consumer service reads events
    loop {
        if eventCh.isEmpty() { break }
        let event = eventCh.receive()
        log info "Dispatching event: " + event
    }

    eventCh.close()
    log info "Channel closed: " + str(eventCh.closed)
}

// ── CircuitBreaker: microservice resilience ───────────────────────────────
task circuitBreakerDemo {
    let cb = new CircuitBreaker({ threshold: 2, timeout: 5000 })

    fn callDownstream(payload) {
        return "response:" + payload
    }

    // Normal calls
    let r1 = cb.call(callDownstream, "ping")
    log info "CB result: " + r1
    log info "CB state: " + cb.state

    // Simulate failure + auto-open
    fn broken() { throw "downstream unavailable" }

    try {
        cb.call(broken)
    } catch e {
        log warn "Call 1 failed: " + str(e)
    }
    try {
        cb.call(broken)
    } catch e {
        log warn "Call 2 failed: " + str(e)
    }

    log info "CB state after failures: " + cb.state

    // Reset manually
    cb.reset()
    log info "CB state after reset: " + cb.state
}

// ── throttle: rate-limiting calls ─────────────────────────────────────────
task throttleDemo {
    var callCount = 0

    fn sendMetric(label) {
        callCount += 1
        log debug "Metric sent: " + label + " (call #" + str(callCount) + ")"
    }

    // Throttle to one call per 500 ms
    let throttledSend = throttle(sendMetric, 500)

    throttledSend("cpu.usage")
    throttledSend("cpu.usage")   // skipped — too soon
    throttledSend("cpu.usage")   // skipped — too soon

    log info "Total metric calls: " + str(callCount)
}

// ── debounce: coalescing rapid calls ─────────────────────────────────────
task debounceDemo {
    var searchValue = ""

    fn executeSearch(query) {
        searchValue = query
        log debug "Searching for: " + query
    }

    // Debounce to fire only after 300 ms of quiet
    let debouncedSearch = debounce(executeSearch, 300)

    debouncedSearch("s")
    debouncedSearch("sp")
    debouncedSearch("spr")
    debouncedSearch("spry")   // only this one should fire on flush

    debouncedSearch.flush()

    log info "Final search value: " + searchValue
}

// ── Full microservice pipeline ────────────────────────────────────────────
task fullPipeline {
    let inbox  = new Queue()
    let outbox = new Channel()
    let cb     = new CircuitBreaker({ threshold: 5 })

    fn process(item) {
        return item * 2
    }

    // Produce
    let nums = [1, 2, 3, 4, 5]
    for n in nums {
        inbox.enqueue(n)
    }

    // Process via circuit breaker, send to channel
    loop {
        if inbox.isEmpty() { break }
        let v = inbox.dequeue()
        let result = cb.call(process, v)
        outbox.send(result)
    }

    // Consume
    let results = []
    loop {
        if outbox.isEmpty() { break }
        results.push(outbox.receive())
    }

    log info "Pipeline results: " + str(results)
}

// ── Micromanage structural pathway until solved ───────────────────────────
task micromanageUntilSolved {
    let backlog = Queue.new([1, 2, 3, 4, 5])
    var total = 0

    let final = micromanage(
        fn(attempt) {
            if backlog.isEmpty() {
                return total
            }
            total = total + backlog.dequeue()
            return total
        },
        fn(lastValue) => backlog.isEmpty(),
        20
    )

    log info "Micromanaged total: " + str(final)
}

// ── EventBus: decoupled pub/sub between microservices ─────────────────────
task eventBusDemo {
    let bus = EventBus.new()
    var processed = []

    // Subscriber service: accumulates items
    bus.subscribe("order.created", fn(order) {
        processed.push(order)
        log debug "Order received: " + str(order)
    })

    // Producer service: publishes events
    let orders = ["order:001", "order:002", "order:003"]
    for o in orders {
        bus.publish("order.created", o)
    }

    log info "Processed orders: " + str(processed.length)
    log info "Subscriber count: " + str(bus.subscriberCount("order.created"))
}

// ── Supervisor: restart failing services until stable ────────────────────
task supervisorDemo {
    let sv = Supervisor.new(3)
    var attempts = 0

    sv.watch("paymentService", fn() {
        attempts += 1
        log debug "Payment service attempt " + str(attempts)
        if attempts < 3 {
            throw "payment service unavailable"
        }
        log info "Payment service is up"
    })

    sv.watch("notifyService", fn() {
        log info "Notify service started"
    })

    let statusMap = sv.start()
    log info "Restart count: " + str(sv.restartCount)
    log info "Service statuses: " + str(statusMap)
}

// ── WorkerPool: drain a task queue through a worker function ─────────────
task workerPoolDemo {
    let pool = WorkerPool.new(fn(item) {
        return item * item
    })

    // Submit work items
    let items = [1, 2, 3, 4, 5]
    for item in items {
        pool.submit(item)
    }

    // Drain the queue until empty (loop until solved)
    pool.run()

    log info "Pool results: " + str(pool.results)
    log info "Pool errors: " + str(pool.errors)
    log info "Pending: " + str(pool.pending)
}

// ── ServiceRegistry + Orchestrator: structural loop pathway ───────────────
task orchestratorDemo {
    let registry = ServiceRegistry.new()
    registry.register("ingest", fn(state, cycle) {
        var base = state
        if base == undefined { base = 0 }
        return base + 2
    })
    registry.register("shape", fn(state) {
        return state - 1
    })

    let orch = Orchestrator.new()
    orch.loadRegistry(registry)

    let solved = orch.runUntilSolved(
        fn(state, cycle) => state >= 7,
        undefined,
        10
    )
    log info "Orchestrated solved value: " + str(solved)
}

// ── micromanage + orchestrator working together ───────────────────────────
task micromanagedOrchestrationDemo {
    let registry = ServiceRegistry.new()
    registry.register("fetch", fn(state, cycle) {
        var base = state
        if base == undefined { base = 1 }
        return base + cycle
    })
    registry.register("stabilize", fn(state) => state * 1)

    let orch = Orchestrator.new()
    orch.loadRegistry(registry)
    var current = undefined

    let final = micromanage(
        fn(attempt) {
            current = orch.runCycle(current, attempt)
            return current
        },
        fn(last, attempt) => last >= 6,
        10
    )
    log info "Micromanaged orchestration final: " + str(final)
}

// ── registry.runUntilSolved + orchestrator.runManaged nested pathway ───────
task nestedManagedLoopDemo {
    let registry = ServiceRegistry.new()
    registry.register("refine", fn(state) {
        if state == undefined { return 1 }
        return state + 1
    })

    let orch = Orchestrator.new()
    orch.addStep("innerRefineLoop", fn(state, cycle) {
        return registry.runUntilSolved("refine", fn(inner) => inner >= 2, state, 5)
    })
    orch.addStep("finalize", fn(state) => state + 1)

    let final = orch.runManaged(fn(state) => state >= 5, undefined, 5)
    log info "Nested managed loop final: " + str(final)
}

// ── orchestrator.addManagedStep loops each microservice step until solved ──
task managedStepDemo {
    let orch = Orchestrator.new()
    orch.addManagedStep(
        "stabilize",
        fn(state, cycle, name, attempt) {
            if state == undefined { return attempt }
            return state + attempt
        },
        fn(state, cycle, name, attempt) => state >= 6,
        5
    )
    orch.addStep("finalize", fn(state) => state + 1)

    let final = orch.runManaged(fn(state) => state >= 9, undefined, 5)
    log info "Managed step final: " + str(final)
}

// ── Entry point ───────────────────────────────────────────────────────────
task main {
    pollUntilReady()
    fetchWithRetry()
    queueDemo()
    channelDemo()
    circuitBreakerDemo()
    throttleDemo()
    debounceDemo()
    fullPipeline()
    micromanageUntilSolved()
    eventBusDemo()
    supervisorDemo()
    workerPoolDemo()
    orchestratorDemo()
    micromanagedOrchestrationDemo()
    nestedManagedLoopDemo()
    managedStepDemo()
}
